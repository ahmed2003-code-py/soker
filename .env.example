# ===== Soker ERP environment =====

# PostgreSQL connection string.
# - Local dev: filled automatically by `npm run pg:start` (embedded Postgres).
# - Production (Railway): paste the Railway PostgreSQL plugin connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Auth.js / NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please"
# App public URL. Local: http://localhost:3000 . Railway: https://<your-app>.up.railway.app
NEXTAUTH_URL="http://localhost:3000"

# ===== OCR (Phase 8) =====
# Engine selector: "tesseract" (default, local) | "ocrspace" | "google"
OCR_ENGINE="tesseract"
# Only needed if OCR_ENGINE != tesseract
OCRSPACE_API_KEY=""
GOOGLE_VISION_API_KEY=""
