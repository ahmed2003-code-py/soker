# ===== Soker ERP environment =====

# PostgreSQL connection string.
# - Local dev: filled automatically by `npm run pg:start` (embedded Postgres).
# - Production (Railway): paste the Railway PostgreSQL plugin connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Auth.js / NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please"
# App public URL. Local: http://localhost:3000 . Railway: https://<your-app>.up.railway.app
NEXTAUTH_URL="http://localhost:3000"

# ===== OCR (Phase 8) =====
# Engine selector: "tesseract" (default, local) | "ocrspace" | "google"
OCR_ENGINE="tesseract"
# Only needed if OCR_ENGINE != tesseract
OCRSPACE_API_KEY=""
GOOGLE_VISION_API_KEY=""

# ===== Backup system (scripts/backup/) =====
# All vars are only needed when running backup/restore scripts, not by the Next.js app.

# Cloudflare R2 — get from R2 dashboard → Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="soker-backups"

# GPG passphrase for AES-256 symmetric encryption of backup files.
# Generate: openssl rand -base64 48
# CRITICAL: Store this in a password manager — losing it = losing access to all backups.
BACKUP_GPG_PASSPHRASE="change-this-to-a-strong-random-passphrase"

# Optional: webhook URL for backup success/failure notifications (Discord or Slack)
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# Leave blank to disable notifications.
BACKUP_ALERT_WEBHOOK_URL=""

# Optional: retention policy overrides (defaults shown)
BACKUP_RETENTION_DAILY="7"
BACKUP_RETENTION_WEEKLY="4"
BACKUP_RETENTION_MONTHLY="12"

# Optional: dump format. 'plain' = SQL+gzip (default). 'custom' = pg_dump -Fc (for large DBs)
BACKUP_FORMAT="plain"
# Optional: parallel jobs for custom format restore (pg_restore -j). Ignored for plain format.
BACKUP_PARALLEL_JOBS="1"

# Optional: temp directory for intermediate backup files (default: /tmp)
BACKUP_TEMP_DIR="/tmp"

# ===== Restore only =====
# Target database URL for restore.ts and test-restore.ts. NEVER point at production.
RESTORE_TARGET_DB="postgresql://USER:PASSWORD@HOST:PORT/soker_restore_test"
# Optional: specific R2 key to restore. Leave blank to use latest daily backup.
RESTORE_BACKUP_KEY=""
